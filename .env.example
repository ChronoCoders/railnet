# Railnet API Environment Configuration
# Copy this file to .env and fill in actual values
# NEVER commit .env to version control

# Server Configuration
# Host to bind API server (use 0.0.0.0 for production)
SERVER_HOST=127.0.0.1

# Port for API server
SERVER_PORT=8080

# Database Configuration
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# Example: postgresql://railnet:secure_password@localhost:5432/railnet
DATABASE_URL=postgresql://localhost/railnet

# Chain Configuration
# WebSocket URL to Railnet node RPC
# Development: ws://127.0.0.1:9944
# Production: ws://validator-01.internal:9944
CHAIN_RPC_URL=ws://127.0.0.1:9944

# Authentication Secrets
# CRITICAL: Generate cryptographically random secrets for production
# Use: openssl rand -base64 64 | tr -d '\n'

# JWT signing secret (minimum 64 characters)
# Used to sign operator JWT tokens
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_STRING

# Admin API key (minimum 64 characters)
# Used for X-Admin-API-Key header authentication
ADMIN_API_KEY=REPLACE_WITH_RANDOM_64_CHAR_STRING

# Admin account seed phrase (for chain root operations)
# Development: Use test mnemonic
# Production: Generate secure mnemonic and store in secrets manager
ADMIN_SEED=bottom drive obey lake curtain smoke basket hold race lonely fit walk//Alice

# JWT Configuration
# Token expiration time in seconds (default: 86400 = 24 hours)
JWT_EXPIRATION=86400

# Rate Limiting Configuration
# Maximum requests per window per operator
RATE_LIMIT_REQUESTS=100

# Rate limit window in seconds (default: 60 = 1 minute)
RATE_LIMIT_WINDOW_SECONDS=60

# Logging Configuration (optional)
# Log level: trace, debug, info, warn, error
# Default: info
# LOG_LEVEL=info

# CORS Configuration (optional)
# Allowed origins for CORS (comma-separated)
# Development: http://localhost:3000
# Production: https://app.railnet.io
# CORS_ALLOWED_ORIGINS=http://localhost:3000

# Performance Tuning (optional)
# Database connection pool size
# DB_POOL_MIN=5
# DB_POOL_MAX=20

# Chain client connection timeout in seconds
# CHAIN_TIMEOUT=30

# Security Notes:
# 1. Generate all secrets with cryptographic randomness
# 2. Rotate JWT_SECRET every 90 days
# 3. Rotate ADMIN_API_KEY every 30 days
# 4. Never log these values
# 5. Use secrets manager in production (AWS Secrets Manager, Vault, etc.)
# 6. Restrict .env file permissions: chmod 600 .env
