---
const links = [
  { label: "Solutions", href: "/solutions" },
  { label: "Technology", href: "/technology" },
  { label: "Security", href: "/security" },
  { label: "Contact", href: "#contact" }
];
---

<footer class="border-t border-white/10">
  <div class="mx-auto max-w-6xl px-5 py-10">
    <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
      <div>
        <div class="text-sm font-semibold tracking-wide">Railnet</div>
        <div class="mt-2 max-w-md text-sm text-white/65">
          Settlement infrastructure for regulated institutions. Private Substrate blockchain with a REST API.
        </div>
      </div>

      <div class="grid grid-cols-2 gap-x-10 gap-y-3 text-sm md:grid-cols-1">
        {links.map((l) => (
          <a href={l.href} class="text-white/70 hover:text-white">
            {l.label}
          </a>
        ))}
      </div>
    </div>

    <div
      class="mt-10 flex flex-col gap-2 border-t border-white/10 pt-6 text-xs text-white/50 md:flex-row md:items-center md:justify-between"
    >
      <div>© {new Date().getFullYear()} Railnet</div>
      <div>Built for production-grade settlement workflows.</div>
    </div>
  </div>
</footer>
