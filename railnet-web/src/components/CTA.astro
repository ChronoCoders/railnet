---
const { title, body } = Astro.props;
---

<div
  id="contact"
  class="rounded-2xl border border-white/10 bg-[radial-gradient(800px_circle_at_20%_0%,rgba(76,125,255,0.35),transparent_55%),radial-gradient(700px_circle_at_85%_50%,rgba(121,161,255,0.18),transparent_55%)] p-8 md:p-10"
>
  <div class="max-w-2xl">
    <div class="text-2xl font-semibold tracking-tight md:text-3xl">{title}</div>
    <div class="mt-3 text-sm text-white/70 md:text-base">{body}</div>

    <div class="mt-7 grid gap-3 md:grid-cols-3">
      <a
        href="mailto:contact@railnet.example"
        class="inline-flex items-center justify-center rounded-lg bg-white px-5 py-3 text-sm font-semibold text-rail-950 hover:bg-white/90"
      >
        Get in touch
      </a>
      <a
        href="/technology"
        class="inline-flex items-center justify-center rounded-lg border border-white/15 bg-white/5 px-5 py-3 text-sm font-semibold text-white hover:bg-white/10"
      >
        How it works
      </a>
      <a
        href="/solutions"
        class="inline-flex items-center justify-center rounded-lg border border-white/15 bg-white/5 px-5 py-3 text-sm font-semibold text-white hover:bg-white/10"
      >
        Use cases
      </a>
    </div>
  </div>
</div>
