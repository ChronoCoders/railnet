---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Card from "../components/Card.astro";
import LogoStrip from "../components/LogoStrip.astro";
import CTA from "../components/CTA.astro";
---

<BaseLayout
  title="Railnet — Solutions"
  description="Solutions built on Railnet: operator networks, asset registry, settlement execution, proofs, and cross-settlements."
>
  <Section
    id="top"
    eyebrow="SOLUTIONS"
    title="Use cases for regulated markets"
    subtitle="Start with the workflows you already have, then digitize them into a predictable, auditable network."
  >
    <div class="grid gap-5 md:grid-cols-2">
      <Card
        title="Private market settlement networks"
        body="Coordinate a permissioned group of participants, define rules, and run settlement workflows under controlled governance."
      >
        <div class="text-xs text-white/55">Operators, permissions, approvals</div>
      </Card>
      <Card
        title="Digital assets for real-world workflows"
        body="Define assets with metadata and settlement rules so participants share a single source of truth for settlement terms."
      >
        <div class="text-xs text-white/55">Asset registry and lifecycle</div>
      </Card>
      <Card
        title="Operational settlement"
        body="Run settlements with clear state changes, predictable controls, and audit-ready records."
      >
        <div class="text-xs text-white/55">Settlement engine</div>
      </Card>
      <Card
        title="Compliance and proof artifacts"
        body="Attach proofs to workflows and support verification and revocation processes for audit and compliance."
      >
        <div class="text-xs text-white/55">Proofs and audit trails</div>
      </Card>
    </div>

    <div class="mt-8">
      <LogoStrip />
    </div>
  </Section>

  <section class="mx-auto max-w-6xl px-5 pb-20 md:pb-28">
    <CTA
      title="Discuss your workflow"
      body="Share your participants, assets, and settlement flow. We’ll map it to a rollout plan and integration path."
    />
  </section>
</BaseLayout>
